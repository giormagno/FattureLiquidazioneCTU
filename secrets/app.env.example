# URL pubblico reale esposto tramite Cloudflare
APP_BASE_URL=https://fatture.example.com

# Ambiente applicativo
APP_ENV=production
APP_DEBUG=0
APP_HOST=0.0.0.0
APP_PORT=18743
APP_SECRET_KEY=change-me-with-a-strong-secret
APP_STORAGE_DIR=/app/storage
APP_LOG_DIR=/app/logs
LOG_LEVEL=INFO

# Waitress
WAITRESS_HOST=0.0.0.0
WAITRESS_PORT=18743
WAITRESS_THREADS=4
WAITRESS_CONNECTION_LIMIT=100

# OpenAI
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

# Resend
RESEND_API_KEY=
MAIL_FROM=
MAIL_REPLY_TO=

# Job automatici
JOB_TIMEZONE=Europe/Rome
JOB_DAEMON_RUN_AT=20:00
JOB_DAEMON_POLL_SECONDS=60

# Playwright / Chromium in container
PLAYWRIGHT_NO_SANDBOX=1
PLAYWRIGHT_DISABLE_DEV_SHM_USAGE=1
